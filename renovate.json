{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>jkroepke/renovate-config:github-action"],
  "packageRules": [
    {
      "matchManagers": [
        "gomod"
      ],
      "versioning": "regex:^v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-0\\.(?<compatibility>\\d+)-(?<digest>[a-z0-9]+)$"
    }
  ]
}
