{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>jkroepke/renovate-config:github-action"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/go.mod$/"
      ],
      "matchStrings": [
        "^require (?<depName>\\S+) v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-0\\.(?<compatibility>\\d+)-(?<digest>[a-z0-9]+)(?: \\/\\/ indirect)?$"
      ],
      "currentValueTemplate": "HEAD",
      "datasourceTemplate": "git-refs",
      "versioningTemplate": "semver"
    }
  ]
}
