{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>jkroepke/renovate-config:github-action"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/go.mod$/"
      ],
      "matchStrings": [
        "require (?<depName>\\S+) v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-0\\.(?<compatibility>\\d+)-(?<currentDigest>[a-z0-9]+)(?: \\/\\/ indirect)?"
      ],
      "currentValueTemplate": "master",
      "packageNameTemplate": "https://{{depName}}",
      "datasourceTemplate": "git-refs"
    }
  ]
}
